# Variables de entorno para comandago_backend
# En local: copiar a application-local.properties o exportar en el shell.

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/comandago
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

APP_JWT_SECRET=
APP_JWT_EXPIRATION_MS=86400000
APP_JWT_REFRESH_EXPIRATION_MS=604800000

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

APP_RATE_LIMIT_LOGIN_MAX=5
APP_RATE_LIMIT_LOGIN_WINDOW=60
